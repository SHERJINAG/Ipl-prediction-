{
  "entities": {
    "Prediction": {
      "title": "Prediction",
      "description": "A match prediction generated by the AI engine.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who generated the prediction." },
        "team1": { "type": "string" },
        "team2": { "type": "string" },
        "venue": { "type": "string" },
        "winner": { "type": "string" },
        "winProbability": { "type": "object" },
        "predictedScore": { "type": "object" },
        "keyInsights": { "type": "array" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "team1", "team2", "winner", "timestamp"]
    },
    "Match": {
      "title": "Match",
      "description": "Historical match data.",
      "type": "object",
      "properties": {
        "match_id": { "type": "string" },
        "date": { "type": "string" },
        "team1": { "type": "string" },
        "team2": { "type": "string" },
        "venue": { "type": "string" },
        "winner": { "type": "string" },
        "team1_score": { "type": "number" },
        "team2_score": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/predictions/{predictionId}": {
      "schema": "Prediction",
      "description": "Collection of match predictions."
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Collection of historical matches."
    }
  }
}
